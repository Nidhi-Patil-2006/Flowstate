{
  "pipeline": [
    {
      "type": "readers.las",
      "filename": "data/raw/THANDALAM.las"
    },
    {
      "type": "filters.reprojection",
      "in_srs": "EPSG:4326",
      "out_srs": "EPSG:32644"
    },
    {
      "type": "writers.gdal",
      "filename": "data/dtm/THANDALAM_DTM.tif",
      "resolution": 1.0,
      "radius": 2.0,
      "output_type": "min",
      "nodata": -9999
    }
  ]
}
